# 루프 시작
addi $t1, $zero, 1        # 원하는 반복 횟수로 바꾸세요. (예: 한 번 더 돌리려면 2)
add  $t3, $t1, $t2
sub  $t3, $t4, $t5
and  $t6, $t7, $t8
or   $t9, $t1, $t2
sw   $t1, 0($t0)
lw   $t8, 0($t0)          # 메모리에서 t1(이전에 저장된 값)을 t8으로
addi $t1, $t1, -1         # 카운터 감소 (프로듀서)
addi $t8, $t8, 10         # <-- 의존성 없는 명령을 사이에 둠 (갭 1)
beq  $t1, $zero, +2       # 0이면 종료(다음 무조건 분기 건너뜀)
beq  $zero, $zero, -10    # 무조건 루프 시작으로 점프
